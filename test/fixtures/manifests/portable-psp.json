{
  "$schema": "https://pocket-stack.dev/schema/pocket-2.json",
  "pocket": 2,
  "id": "dev.pocket-stack.telemetry",
  "name": "pocket-telemetry",
  "title": "Pocket Telemetry",
  "version": "0.1.0",
  "engine": {
    "abi": 1,
    "capabilities": {
      "requires": [
        { "id": "ui.drawlist", "version": 1 },
        { "id": "text.glyphs.baked", "version": 1 },
        { "id": "input.analog", "version": 1, "parameters": { "sticks": 1 } },
        { "id": "input.buttons", "version": 1 }
      ]
    }
  },
  "app": {
    "entry": "app/main.tsx",
    "framework": "solid",
    "simulationHz": 60,
    "viewport": {
      "logical": [480, 272],
      "presentation": "integer-fit"
    }
  },
  "packages": {
    "psp": {
      "title": "Pocket Telemetry",
      "icon0": "art/ICON0.png",
      "pic1": "art/PIC1.png",
      "memoryBudgetMb": 20
    }
  }
}
